# RapidAPI key - get at https://rapidapi.com
# Subscribe to "Zillow56" API (free tier: 50 requests/month)
RAPIDAPI_KEY=your_rapidapi_key_here

# Mapbox public token - get at https://account.mapbox.com
# Create an account, go to Access Tokens, copy the default public token (starts with pk.)
MAPBOX_TOKEN=pk.your_mapbox_token_here

# Server port (optional, defaults to 3000)
PORT=3000

# Set to "true" to use local mock data instead of calling RapidAPI (useful during development)
USE_MOCK=false
